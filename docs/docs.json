{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenScience",
  "colors": {
    "primary": "#0d9488",
    "light": "#14b8a6",
    "dark": "#0d9488"
  },
  "logo": {
    "light": "/images/wordmark.svg",
    "dark": "/images/wordmark.svg",
    "href": "https://openscience.sh"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/synthetic-sciences/openscience"
      }
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/synthetic-sciences/openscience"
        },
        {
          "anchor": "npm",
          "icon": "package",
          "href": "https://www.npmjs.com/package/@synsci/openscience"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting started",
        "pages": ["index", "installation"]
      },
      {
        "group": "Configuration",
        "pages": ["config", "models", "providers", "permissions", "rules", "themes"]
      },
      {
        "group": "Agents and tools",
        "pages": ["agents", "tools", "mcp-servers", "skills"]
      },
      {
        "group": "Platform",
        "pages": ["atlas", "share"]
      },
      {
        "group": "Reference",
        "pages": ["cli", "troubleshooting", "contributing"]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/synthetic-sciences/openscience"
    }
  }
}
